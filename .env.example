# --- Конфигурация базы данных PostgreSQL ---
POSTGRESQL_DATABASE=inventory
POSTGRESQL_USER=inventory_user
POSTGRESQL_PASSWORD=set_a_secure_database_password_here

# --- Секретный ключ Flask (сессии, куки, CSRF-защита) ---
# Сгенерируйте случайную длинную строку, например, с помощью: openssl rand -hex 32
SECRET_KEY=set_a_secure_random_flask_secret_key_here

# --- Секрет регистрации osquery-агентов (Enroll Secret) ---
# Секретный токен, который агенты предъявляют серверу при первой регистрации
ENROLL_SECRET=set_a_secure_osquery_enroll_secret_here
